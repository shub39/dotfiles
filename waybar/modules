{
"hyprland/workspaces": {
	"active-only": false,
    "all-outputs": true, 
    "format": "{icon}",
    "show-special": false,
    "on-click": "activate",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": []
    },
    "format-icons": {
      "active": "ΎζΥ",
      "default": "ΎΗΖ"
	} 
},
       
"bluetooth": {
    "format": "ΎΛΥ",
    "format-disabled": "≤░Γ│",
    "format-connected": "≤░Γ▒ {num_connections}",
    "tooltip-format": "ΎΛΥ {device_alias}",
    "tooltip-format-connected": "{device_enumerate}",
    "tooltip-format-enumerate-connected": "ΎΛΥ {device_alias} ≤░ΓΕ{device_battery_percentage}%",
    "tooltip": true,
    "on-click": "blueman-manager"
},
     
"clock": {
    "interval": 1,
    "format": "ΎΑΩ  {:%H:%M}",
    "format-alt": "ΎΑΩ  {:%H:%M  ΎΒ│   %Y, %d %B, %A}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode"          : "year",
      "mode-mon-col"  : 3,
      "weeks-pos"     : "right",
      "on-scroll"     : 1,
      "format": {
      "days":       "<span color='#ecc6d9'><b>{}</b></span>",
      "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
      "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
      "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
                }
                }
    },              
    "actions":  {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
},
   
"cpu": {
    "format": "{usage}% ≤░Ξδ",  
    "interval": 1,
    "format-alt-click": "click",
    "format-alt": "{icon0}{icon1}{icon2}{icon3} {usage:>2}% ≤░Ξδ",
    "format-icons": ["έΨΒ", "έΨΓ", "έΨΔ", "έΨΕ", "έΨΖ", "έΨΗ", "έΨΘ", "έΨΙ"],
    "on-click-right": "gnome-system-monitor"
},
         
"hyprland/window": {
    "format": "{}",
    "max-length": 40,
    "separate-outputs": true,
    "offscreen-css" : true,
    "offscreen-css-text": "(inactive)",
     "rewrite": {
          "(.*) έΑΦ Mozilla Firefox": "ΎΚσ $1",
          "(.*) - fish": "> [$1]",
      "(.*) - zsh": "> [$1]",
      "(.*) - kitty": "> [$1]"
    }
},
  
"memory": {
    "interval": 10,
    "format": "{used:0.1f}G ≤░╛Η",
    "format-alt": "{percentage}% ≤░╛Η",
    "format-alt-click": "click",
    "tooltip": true,
    "tooltip-format": "{used:0.1f}GB/{total:0.1f}G",
    "on-click-right": "kitty --title btop sh -c 'btop'"
},

"mpris": {
    "interval": 10,
	"format": "{player_icon} ",
	"format-paused": "{status_icon} <i>{dynamic}</i>",
	"on-click": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "scroll-step": 5.0,
    "smooth-scrolling-threshold": 1,
	"player-icons": {
        "chromium": "ΎΚρ",
		"default": "ΎΑζ",
        "firefox": "ΎΚσ",
        "kdeconnect": "Ύαθ",
        "mopidy": "ΎΑΒ",
		"mpv": "≤░Ρ╣",
        "spotify": "ΎΗ╝",
		"vlc": "≤░Χ╝"
	},
	"status-icons": {
		"paused": "≤░ΡΟ",
        "playing": "ΎΒΜ",
        "stopped": "ΎΒΞ"
	},
	"max-length": 30
},

"network#speed": {
    "interval": 1,
    "format": "{ifname}",
    "format-wifi": "{icon} ΎΕ╣ {bandwidthUpBytes} ΎΕ║ {bandwidthDownBytes}",
    "format-ethernet": "≤░Να  ΎΕ╣ {bandwidthUpBytes} ΎΕ║ {bandwidthDownBytes}",
    "format-disconnected": "≤░Νβ", 
    "tooltip-format": "{ipaddr}",
    "format-linked": "≤░ΙΒ {ifname} (No IP)",
    "tooltip-format-wifi": "{essid} {icon} {signalStrength}%",
    "tooltip-format-ethernet": "{ifname} ≤░Να",
    "tooltip-format-disconnected": "≤░Νβ Disconnected",
    "max-length": 50,
    "format-icons": ["≤░νψ","≤░νθ","≤░νλ","≤░νξ","≤░νρ"]
},
      
"pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-bluetooth": "{icon} ≤░Γ░ {volume}%",
    "format-muted": "≤░ΨΒ",
    "format-icons": {
        "headphone": "ΎΑξ",
        "hands-free": "ΎΑξ",
        "headset": "ΎΑξ",
        "phone": "ΎΓΧ",
        "portable": "ΎΓΧ",
        "car": "ΎΗ╣",
    "default": ["ΎΑο", "ΎΑπ", "≤░Χ╛", "ΎΑρ"], 
    "ignored-sinks": ["Easy Effects Sink"]
    },
    "scroll-step": 5.0,
    "on-click": "pavucontrol -t 3",
	"tooltip-format": "{icon} {desc} | {volume}%",
    "smooth-scrolling-threshold": 1
},
      
"pulseaudio#microphone": {
    "format": "{format_source}",
    "format-source": "{volume}%",
    "format-source-muted": " ΎΕ▒",
    "on-click-right": "pavucontrol -t 4",
	"tooltip-format": "{source_desc} | {source_volume}%",
    "scroll-step": 5
},
    
"temperature": {
    "interval": 10,
    "tooltip": true,
    "hwmon-path": ["/sys/class/hwmon/hwmon1/temp1_input", "/sys/class/thermal/thermal_zone0/temp"],
    "critical-threshold": 82,
    "format-critical": "{temperatureC}┬░C {icon}",
    "format": "{temperatureC}┬░C {icon}",
    "format-icons": ["≤░Ι╕"],
    "on-click-right": "kitty --title nvtop sh -c 'nvtop'"
},
                    
"custom/menu": {
    "format": "ΎΖ╝{}",
    "exec": "echo ; echo ≤▒Υθ app launcher",
    "interval" : 86400,
    "tooltip": true,
    "on-click": "rofi -config ~/.config/dotfiles/rofi/config.rasi -show drun"
},

"custom/swaync": {
    "tooltip":true,     
    "format": "{icon}  {}",
    "format-icons": {
      "notification": "ΎΓλ<span foreground='red'><sup>ΎΣΕ</sup></span>",
      "none": "ΎΓλ",
      "dnd-notification": "ΎΘ╖<span foreground='red'><sup>ΎΣΕ</sup></span>",
      "dnd-none": "ΎΘ╖",
      "inhibited-notification": "ΎΓλ<span foreground='red'><sup>ΎΣΕ</sup></span>",
      "inhibited-none": "ΎΓλ",
      "dnd-inhibited-notification": "ΎΘ╖<span foreground='red'><sup>ΎΣΕ</sup></span>",
      "dnd-inhibited-none": "ΎΘ╖"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "sleep 0.1 && swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
},
 
"custom/separator#dot-line": {
    "format": "Όακ",
    "interval": "once",
    "tooltip": false
}
}